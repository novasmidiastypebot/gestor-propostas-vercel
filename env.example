# Credenciais da Efí
EFI_CLIENT_ID=Client_Id_...
EFI_CLIENT_SECRET=Client_Secret_...

# Certificado em Base64 (RECOMENDADO)
# Para converter: cat certificado.p12 | base64
EFI_CERTIFICATE_BASE64=MIIKsQIBAzCCCn...

# OU caminho do certificado (alternativa)
# EFI_CERTIFICATE_PATH=/path/to/certificado.p12

# Ambiente (producao ou homologacao)
EFI_AMBIENTE=homologacao

# Chave de API para autenticar requisições do Base44
# Gere uma chave forte: openssl rand -hex 32
PROXY_API_KEY=sua_chave_secreta_aqui_32_caracteres_minimo